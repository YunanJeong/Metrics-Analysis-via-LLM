# ==========================================================
# 🚀 AI 서버 리포터 설정 (0.env)
# ==========================================================

# [1] Prometheus 서버 주소
PROM_URL="http://monitor.wai:9090"

# [2] AI (LLM) 엔진 설정 (기본값: 로컬 LLM)
# ----------------------------------------------------------

# --- [선택 1] 로컬 LLM 사용 (Ollama 등 기본값) ---
AI_TYPE="local"
AI_MODEL="qwen3.5:9b"
AI_API_URL="http://localhost:11434"
AI_API_KEY="not-needed"

# --- [선택 2] 상용 API 사용 (OpenAI 등 클라우드 서비스) ---
# AI_TYPE="api"
# AI_MODEL="gpt-4o"
# AI_API_KEY="sk-..."
# AI_API_URL="https://api.openai.com/v1"

# ----------------------------------------------------------

# [3] 리포트 메일 설정
MAIL_RECIPIENT="your-email@example.com"
MAIL_SUBJECT="[SRE 리포트] 서버 상태 분석 리포트"
