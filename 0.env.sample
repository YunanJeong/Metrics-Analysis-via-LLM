# ==========================================================
# 🚀 AI 서버 리포터 설정 (0.env)
# ==========================================================

# [1] Prometheus 서버 대상 목록 (형식: "라벨|URL")
# ----------------------------------------------------------

# 방법 1: 단일 서버 설정
# PROM_TARGETS="PRODUCTION-SEOUL|http://monitor.wai:9090"

# 방법 2: 여러 서버를 줄바꿈으로 구분하여 설정 (권장)
PROM_TARGETS="
PRODUCTION-SEOUL|http://monitor.wai:9090
STAGING-TOKYO|http://staging-monitor:9090
DEVELOP-OFFICE|http://office-monitor:9090
"

# ----------------------------------------------------------

# [2] AI (LLM) 엔진 설정
# ----------------------------------------------------------
# 아래 3가지 옵션 중 하나를 선택하여 주석을 해제하고 사용하세요.

# --- [선택 1] 로컬 LLM 사용 (Ollama 등) ---
AI_TYPE="local"
AI_MODEL="qwen3.5:9b"              # Ollama에서 사용 가능한 모델명
AI_API_URL="http://localhost:11434"
AI_API_KEY="not-needed"

# --- [선택 2] 상용 API 사용 (OpenAI 등) ---
# AI_TYPE="api"
# AI_MODEL="gpt-4o"                 # 또는 gpt-4, gpt-3.5-turbo 등
# AI_API_KEY="sk-..."               # OpenAI API Key
# AI_API_URL="https://api.openai.com/v1"

# --- [선택 3] AWS Bedrock 사용 ---
# AI_TYPE="bedrock"
# AI_MODEL="arn:aws:bedrock:ap-northeast-2::foundation-model/anthropic.claude-3-7-sonnet-20250219-v1:0"
# AWS_REGION="ap-northeast-2"       # Bedrock 사용 리전 (예: us-east-1, ap-northeast-2 등)
#
# [주의사항] AWS CLI 인증이 필요합니다:
#   방법 1: aws configure 실행
#   방법 2: 환경변수 설정 (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
#   방법 3: IAM Role 사용 (EC2, Lambda 등)
#
# [모델 ID 찾기]
#   $ aws bedrock list-foundation-models --region ap-northeast-2 --query 'modelSummaries[?contains(modelId, `claude`)].modelId'
#
# [일반적인 모델 ID 예시]
#   - Claude 3.7 Sonnet:  anthropic.claude-3-7-sonnet-20250219-v1:0
#   - Claude 3.5 Sonnet:  anthropic.claude-3-5-sonnet-20240620-v1:0
#   - Claude 3 Sonnet:    anthropic.claude-3-sonnet-20240229-v1:0
#   - Claude 3 Haiku:     anthropic.claude-3-haiku-20240307-v1:0

# ----------------------------------------------------------

# [3] AI 프롬프트 커스터마이징 (선택사항)
# ----------------------------------------------------------
# 기본 프롬프트가 제공되므로 설정하지 않아도 됩니다.
# 필요시 아래처럼 AI_PROMPT 변수로 프롬프트를 오버라이드할 수 있습니다.
#
# AI_PROMPT="
# You are an SRE expert. Analyze the metrics and provide insights.
# Focus on anomalies and resource usage trends.
# Output in Korean, plain text only.
# "
#

# ----------------------------------------------------------

# [4] 리포트 메일 설정
MAIL_RECIPIENT="your-email@example.com"
MAIL_SUBJECT="[SRE 리포트] 서버 상태 분석 리포트"

# 발신자 정보 (선택사항)
# FROM_NAME="SRE Bot"
# FROM_ADDR="noreply@yourcompany.com"

# SMTP 서버 설정 (선택사항)
# SMTP_SERVER="smtp.yourcompany.com"
# SMTP_PORT="25"
